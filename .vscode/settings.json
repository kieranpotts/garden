  /* Enable support for embedded diagrams in AsciiDoc, via Kroki */
  "asciidoc.extensions.enableKroki": true,
  "asciidoc.preview.asciidoctorAttributes": {
    "kroki-server-url": "http://localhost:8080",
  },

}
